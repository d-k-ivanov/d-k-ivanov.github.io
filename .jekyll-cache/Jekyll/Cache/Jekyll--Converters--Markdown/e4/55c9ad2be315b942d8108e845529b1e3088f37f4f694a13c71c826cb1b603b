<span class="nv">SUBSYSTEM</span><span class="o">==</span><span class="s2">"power_supply"</span>, ENV<span class="o">{</span>POWER_SUPPLY_ONLINE<span class="o">}==</span><span class="s2">"1"</span>, ENV<span class="o">{</span>DISPLAY<span class="o">}=</span><span class="s2">":0"</span>, ENV<span class="o">{</span>XAUTHORITY<span class="o">}=</span><span class="s2">"/home/</span><span class="nv">$USER</span><span class="s2">/.Xauthority"</span>, RUN+<span class="o">=</span><span class="s2">"/usr/local/bin/lid_action.sh AC"</span>
