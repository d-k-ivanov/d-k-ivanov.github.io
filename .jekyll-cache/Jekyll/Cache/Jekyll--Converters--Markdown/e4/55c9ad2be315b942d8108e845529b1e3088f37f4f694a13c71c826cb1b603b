<h3 id="fstab">fstab</h3>

<div class="language-bash highlighter-rouge"><div class="highlight"><pre class="highlight"><code>fallocate <span class="nt">-l</span> 8192M /swapfile
<span class="nb">dd </span><span class="k">if</span><span class="o">=</span>/dev/zero <span class="nv">of</span><span class="o">=</span>/swapfile <span class="nv">bs</span><span class="o">=</span>1M <span class="nv">count</span><span class="o">=</span>8192
<span class="nb">chmod </span>600 /swapfile
mkswap /swapfile
swapon /swapfile
blkid

<span class="c">#----    fstab   ----</span>
<span class="nv">UUID</span><span class="o">=</span><span class="s2">"XXX"</span> /boot         vfat rw,relatime,fmask<span class="o">=</span>0022,dmask<span class="o">=</span>0022,codepage<span class="o">=</span>437,iocharset<span class="o">=</span>iso8859-1,shortname<span class="o">=</span>mixed,errors<span class="o">=</span>remount-ro 0 2
<span class="nv">UUID</span><span class="o">=</span><span class="s2">"XXX"</span> /             ext4 rw,relatime,data<span class="o">=</span>ordered                                                                             0 1
<span class="nv">UUID</span><span class="o">=</span><span class="s2">"XXX"</span> /home/storage ext4 rw,relatime,data<span class="o">=</span>ordered                                                                             1 1
<span class="c">#Swap</span>
/swapfile  none          swap defaults                                                                                             0 0
<span class="c">#--------------------</span>
</code></pre></div></div>

